# ─────────────────────────────────────────────────────────────
# Configuration SMTP — envoi des emails du formulaire de contact
# Copiez ce fichier en ".env.local" et renseignez vos valeurs.
# ─────────────────────────────────────────────────────────────

# Hôte SMTP
#   Gmail    : smtp.gmail.com
#   Outlook  : smtp-mail.outlook.com
SMTP_HOST=smtp.gmail.com

# Port SMTP
#   465 = SSL (recommandé)   |   587 = STARTTLS
SMTP_PORT=465

# Identifiants SMTP
#   SMTP_USER = votre adresse Gmail complète
#   SMTP_PASS = un "mot de passe d'application" Gmail (PAS votre mot de passe habituel)
#   → Activez la validation en 2 étapes puis créez un App Password :
#     https://myaccount.google.com/apppasswords
SMTP_USER=votreadresse@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Adresse de réception des demandes (où arrivent les leads)
MAIL_TO=gmdgroup@outlook.fr

# Expéditeur affiché (optionnel — par défaut = SMTP_USER)
MAIL_FROM="DOT CAKE — Site" <votreadresse@gmail.com>
